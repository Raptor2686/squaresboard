# SquaresBoard Backend Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────────────────────────
# Default: local SQLite (no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./squaresboard.db

# ─── Stripe ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — set after running: stripe listen --forward-to localhost:8000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Sports Data (TheSportsDB) ─────────────────────────────────────────────
# Free API key: https://www.thesportsdb.com — sign up, key is on your profile page
THESPORTSDB_API_KEY=your_key_here

# ─── App ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
SECRET_KEY=change-this-to-a-random-string-in-production
